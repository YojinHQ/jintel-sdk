{
  "mcpServers": {
    "jintel": {
      "command": "npx",
      "args": ["-y", "@yojinhq/jintel-mcp"],
      "env": {
        "JINTEL_API_KEY": "${JINTEL_API_KEY}",
        "JINTEL_WALLET_PRIVATE_KEY": "${JINTEL_WALLET_PRIVATE_KEY}",
        "JINTEL_X402_MAX_VALUE": "${JINTEL_X402_MAX_VALUE}"
      }
    }
  }
}
